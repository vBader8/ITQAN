# Supabase project settings — see https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: override the Quran.com API base URL (e.g. to point at a local
# mock during development). Defaults to https://api.quran.com/api/v4.
# QURAN_API_BASE_URL=

# Optional: override the hadith-api base URL. Defaults to the jsDelivr CDN
# mirror (https://cdn.jsdelivr.net/gh/fawazahmed0/hadith-api@1).
# HADITH_API_BASE_URL=

# Required for the AI Assistant feature — get a key at
# https://console.anthropic.com/settings/keys. Without it, the assistant
# page shows a "not configured" state instead of a chat.
ANTHROPIC_API_KEY=

# Optional: override the model the assistant uses. Defaults to claude-sonnet-5.
# ASSISTANT_MODEL=
